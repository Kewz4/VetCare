@model VetCareSV.Models.Mascota
@{ ViewData["Title"] = "Detalle de Mascota"; }
<div class="vc-container" style="padding-top:2rem;">
    <div class="vc-form-header">
        <a asp-action="Index" class="vc-back-link">← Mis Mascotas</a>
        <div class="vc-header-actions">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="vc-btn-ghost-sm">Editar</a>
        </div>
    </div>
    <div class="vc-detail-layout">
        <div class="vc-card vc-pet-detail-card">
            <div class="vc-pet-icon-large">@Html.Raw(Model.Especie == "Perro" ? """<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="width:64px;height:64px;color:var(--mint)"><ellipse cx="12" cy="17" rx="5" ry="3.5"/><ellipse cx="6.5" cy="11" rx="2" ry="3"/><ellipse cx="17.5" cy="11" rx="2" ry="3"/><ellipse cx="9" cy="7" rx="1.5" ry="2"/><ellipse cx="15" cy="7" rx="1.5" ry="2"/></svg>""" : Model.Especie == "Gato" ? """<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="width:64px;height:64px;color:var(--mint)"><path d="M12 5C9 5 6 7 6 10c0 4 2 7 6 8 4-1 6-4 6-8 0-3-3-5-6-5z"/><path d="M6 5 4 3M18 5l2-2"/></svg>""" : """<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="width:64px;height:64px;color:var(--mint)"><ellipse cx="12" cy="13" rx="5" ry="7"/><path d="M7 8c-2-1-3-3-2-5M17 8c2-1 3-3 2-5"/></svg>""")</div>
            <h2>@Model.Nombre</h2>
            <div class="vc-detail-grid">
                <div class="vc-detail-item">
                    <span class="vc-detail-label">Especie</span>
                    <span class="vc-detail-value">@Model.Especie</span>
                </div>
                @if (!string.IsNullOrEmpty(Model.Raza))
                {
                    <div class="vc-detail-item">
                        <span class="vc-detail-label">Raza</span>
                        <span class="vc-detail-value">@Model.Raza</span>
                    </div>
                }
                @if (Model.Edad.HasValue)
                {
                    <div class="vc-detail-item">
                        <span class="vc-detail-label">Edad</span>
                        <span class="vc-detail-value">@Model.Edad año(s)</span>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.Color))
                {
                    <div class="vc-detail-item">
                        <span class="vc-detail-label">Color</span>
                        <span class="vc-detail-value">@Model.Color</span>
                    </div>
                }
            </div>
            <div style="margin-top:1.5rem;display:flex;gap:0.75rem;flex-wrap:wrap;">
                <a asp-controller="Citas" asp-action="Create" class="vc-btn-primary">Agendar Cita</a>
                <a asp-controller="HistorialMedico" asp-action="Mascota" asp-route-mascotaId="@Model.Id" class="vc-btn-ghost">Historial Médico</a>
            </div>
        </div>
        <div>
            <h3 class="vc-section-subtitle">Citas Recientes</h3>
            @if (!Model.Citas.Any())
            {
                <div class="vc-empty-state">
                    <div class="vc-empty-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg></div>
                    <p>Sin citas registradas aún.</p>
                </div>
            }
            else
            {
                <div class="vc-citas-list">
                    @foreach (var c in Model.Citas.OrderByDescending(x => x.Fecha).Take(5))
                    {
                        <div class="vc-cita-row">
                            <div>
                                <strong>@c.Fecha.ToString("dd/MM/yyyy HH:mm")</strong>
                                <small>@c.Veterinaria?.Nombre</small>
                            </div>
                            <span class="vc-badge vc-badge--@c.Estado.ToLower()">@c.Estado</span>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>
