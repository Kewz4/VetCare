@{ ViewData["Title"] = "Inicio"; }

<!-- HERO -->
<section class="vc-hero">
    <div class="vc-hero-content">
        <h1 class="vc-hero-title">Tu mascota merece<br><em>la mejor atención</em></h1>
        <p class="vc-hero-sub">Agenda citas veterinarias, lleva el historial médico completo y descubre comercios aliados cerca de ti — todo desde un solo lugar, sin llamadas ni papeleo.</p>
        <div class="vc-hero-actions">
            @if (Context.Session.GetInt32("UsuarioId") != null)
            {
                <a asp-controller="Citas" asp-action="Create" class="vc-btn-primary">Agendar Cita</a>
                <a asp-controller="Mascotas" asp-action="Index" class="vc-btn-ghost">Mis Mascotas</a>
            }
            else
            {
                <button class="vc-btn-primary" onclick="openRegisterModal()">Comenzar gratis</button>
                <a asp-controller="Veterinarias" asp-action="Index" class="vc-btn-ghost">Ver Veterinarias</a>
            }
        </div>
        <div class="vc-hero-trust">
            <div class="vc-trust-item">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="vc-icon-sm"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                Datos seguros
            </div>
            <div class="vc-trust-item">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="vc-icon-sm"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                Disponible 24/7
            </div>
            <div class="vc-trust-item">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="vc-icon-sm"><polyline points="20 6 9 17 4 12"/></svg>
                Registro gratuito
            </div>
        </div>
    </div>
    <div class="vc-hero-pets">
        <img src="https://1rdekw89rj.ucarecd.net/de2fb12e-690b-4a05-a89d-b96c1a5b2b0c/dog.png" alt="Perro" class="vc-hero-dog" />
        <img src="https://1rdekw89rj.ucarecd.net/763e0416-69f4-4653-84e8-ff20897cb2b8/cat.png" alt="Gato" class="vc-hero-cat" />
    </div>
</section>

<!-- MODULOS -->
<section class="vc-features">
    <div class="vc-container">
        <p class="vc-section-eyebrow">Plataforma completa</p>
        <h2 class="vc-section-title">Todo lo que necesitas<br>para cuidar a tu mascota</h2>
        <div class="vc-features-grid">
            <div class="vc-feature-card">
                <div class="vc-feature-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg></div>
                <h3>Citas en línea</h3>
                <p>Agenda, modifica o cancela citas veterinarias desde cualquier dispositivo, sin llamadas ni filas.</p>
            </div>
            <div class="vc-feature-card">
                <div class="vc-feature-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/><path d="M9 12h6M9 16h4"/></svg></div>
                <h3>Historial médico</h3>
                <p>Diagnósticos, tratamientos y vacunas de cada mascota, siempre organizados y accesibles.</p>
            </div>
            <div class="vc-feature-card">
                <div class="vc-feature-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l1-5h16l1 5"/><path d="M3 9a2 2 0 0 0 4 0 2 2 0 0 0 4 0 2 2 0 0 0 4 0 2 2 0 0 0 4 0"/><path d="M5 9v11a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V9"/><path d="M10 14h4v6h-4z"/></svg></div>
                <h3>Comercios aliados</h3>
                <p>Directorio de tiendas, farmacias y grooming en los 14 departamentos de El Salvador.</p>
            </div>
            <div class="vc-feature-card">
                <div class="vc-feature-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><ellipse cx="12" cy="17" rx="5" ry="3.5"/><ellipse cx="6.5" cy="11" rx="2" ry="3"/><ellipse cx="17.5" cy="11" rx="2" ry="3"/><ellipse cx="9" cy="7" rx="1.5" ry="2"/><ellipse cx="15" cy="7" rx="1.5" ry="2"/></svg></div>
                <h3>Perfil de mascotas</h3>
                <p>Registra todos tus perros, gatos y aves con especie, raza, edad y color en un solo perfil.</p>
            </div>
        </div>
    </div>
</section>

<!-- PARA QUIEN ES -->
<section class="vc-audience">
    <div class="vc-container">
        <p class="vc-section-eyebrow">Dos tipos de cuenta</p>
        <h2 class="vc-section-title">Pensado para dueños<br>y para negocios</h2>
        <div class="vc-audience-grid">
            <div class="vc-audience-card">
                <div class="vc-audience-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><ellipse cx="12" cy="17" rx="5" ry="3.5"/><ellipse cx="6.5" cy="11" rx="2" ry="3"/><ellipse cx="17.5" cy="11" rx="2" ry="3"/><ellipse cx="9" cy="7" rx="1.5" ry="2"/><ellipse cx="15" cy="7" rx="1.5" ry="2"/></svg>
                </div>
                <h3>Dueños de mascotas</h3>
                <p>Crea una cuenta gratuita, registra tus mascotas y empieza a agendar citas en minutos.</p>
                <ul class="vc-audience-list">
                    <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="vc-icon-xs"><polyline points="20 6 9 17 4 12"/></svg> Mascotas ilimitadas</li>
                    <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="vc-icon-xs"><polyline points="20 6 9 17 4 12"/></svg> Citas 24/7</li>
                    <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="vc-icon-xs"><polyline points="20 6 9 17 4 12"/></svg> Historial médico por mascota</li>
                    <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="vc-icon-xs"><polyline points="20 6 9 17 4 12"/></svg> Directorio de comercios</li>
                </ul>
                @if (Context.Session.GetInt32("UsuarioId") == null)
                {
                    <button class="vc-btn-primary" onclick="openRegisterModal()">Crear cuenta gratis</button>
                }
            </div>
            <div class="vc-audience-card vc-audience-card--comercio">
                <div class="vc-audience-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l1-5h16l1 5"/><path d="M3 9a2 2 0 0 0 4 0 2 2 0 0 0 4 0 2 2 0 0 0 4 0 2 2 0 0 0 4 0"/><path d="M5 9v11a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V9"/><path d="M10 14h4v6h-4z"/></svg>
                </div>
                <h3>Negocios y comercios</h3>
                <p>Registra tu tienda, farmacia o clínica en el directorio y conecta con dueños en todo el país.</p>
                <ul class="vc-audience-list">
                    <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="vc-icon-xs"><polyline points="20 6 9 17 4 12"/></svg> Perfil en directorio público</li>
                    <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="vc-icon-xs"><polyline points="20 6 9 17 4 12"/></svg> Visibilidad por departamento</li>
                    <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="vc-icon-xs"><polyline points="20 6 9 17 4 12"/></svg> Panel de gestión propio</li>
                    <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="vc-icon-xs"><polyline points="20 6 9 17 4 12"/></svg> Categorización por tipo</li>
                </ul>
                @if (Context.Session.GetInt32("UsuarioId") == null)
                {
                    <a asp-controller="Comercios" asp-action="RegistroComercio" class="vc-btn-ghost">Registrar mi comercio</a>
                }
            </div>
        </div>
    </div>
</section>

<!-- PASOS -->
<section class="vc-steps">
    <div class="vc-container">
        <p class="vc-section-eyebrow">Así de simple</p>
        <h2 class="vc-section-title">Empieza en tres pasos</h2>
        <div class="vc-steps-grid">
            <div class="vc-step">
                <div class="vc-step-num">01</div>
                <h3>Crea tu cuenta</h3>
                <p>Regístrate gratis con tu email. En menos de un minuto tienes acceso completo.</p>
            </div>
            <div class="vc-step-arrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg></div>
            <div class="vc-step">
                <div class="vc-step-num">02</div>
                <h3>Registra tu mascota</h3>
                <p>Agrega el nombre, especie, raza y edad. Puedes tener varios perfiles activos.</p>
            </div>
            <div class="vc-step-arrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg></div>
            <div class="vc-step">
                <div class="vc-step-num">03</div>
                <h3>Agenda tu cita</h3>
                <p>Elige veterinaria, fecha y hora. Tu cita queda registrada al instante.</p>
            </div>
        </div>
    </div>
</section>

<!-- CTA -->
@if (Context.Session.GetInt32("UsuarioId") == null)
{
<section class="vc-cta">
    <div class="vc-container">
        <div class="vc-cta-box">
            <h2>¿Listo para empezar?</h2>
            <p>Únete a VetCare SV y dale a tu mascota el seguimiento que merece.</p>
            <button class="vc-btn-primary" onclick="openRegisterModal()">Crear cuenta gratis</button>
        </div>
    </div>
</section>
}
