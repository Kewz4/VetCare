@{ ViewData["Title"] = "Diagnóstico DB"; Layout = "_Layout"; }
<div class="vc-page-wrapper" style="max-width:700px;margin:3rem auto;padding:2rem;">
    <h1 style="color:var(--teal);margin-bottom:1.5rem;">Estado de la Base de Datos</h1>
    <pre style="background:rgba(255,255,255,0.05);border:1px solid rgba(62,207,178,0.2);border-radius:8px;padding:1.5rem;color:var(--white);font-size:0.9rem;line-height:1.7;white-space:pre-wrap;">@ViewBag.Info</pre>
    <a href="/" class="vc-btn-ghost" style="display:inline-block;margin-top:1.5rem;">Volver al inicio</a>
</div>
