@model IEnumerable<VetCareSV.Models.Veterinaria>
@{ ViewData["Title"] = "Veterinarias"; }
<div class="vc-container" style="padding-top:2rem;">
    <div class="vc-page-header">
        <div>
            <h1>Veterinarias</h1>
            <p>Encuentra clínicas veterinarias en todo El Salvador</p>
        </div>
    </div>
    <form method="get" class="vc-search-bar">
        <div class="vc-field" style="flex:1;">
            <input type="text" name="termino" value="@ViewBag.Termino" placeholder="Buscar por nombre o dirección..." />
        </div>
        <div class="vc-field">
            <select name="departamento">
                <option value="">Todos los departamentos</option>
                @foreach (var d in new[] { "San Salvador", "Santa Ana", "La Libertad", "San Miguel", "Sonsonate", "Ahuachapán", "La Paz", "Usulután" })
                {
                    <option value="@d" selected="@(ViewBag.Departamento == d ? "selected" : null)">@d</option>
                }
            </select>
        </div>
        <button type="submit" class="vc-btn-primary">Buscar</button>
        @if (!string.IsNullOrEmpty(ViewBag.Termino as string) || !string.IsNullOrEmpty(ViewBag.Departamento as string))
        {
            <a asp-action="Index" class="vc-btn-ghost">Limpiar</a>
        }
    </form>

    @if (!Model.Any())
    {
        <div class="vc-empty-state">
            <div class="vc-empty-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/></svg>
            </div>
            <p>No se encontraron veterinarias con esos criterios.</p>
            <a asp-action="Index" class="vc-btn-ghost">Ver todas</a>
        </div>
    }
    else
    {
        <div class="vc-cards-grid">
            @foreach (var v in Model)
            {
                <div class="vc-card vc-vet-card">
                    <div class="vc-card-icon-svg">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/></svg>
                    </div>
                    <div class="vc-card-body">
                        <h3>@v.Nombre</h3>
                        <p class="vc-card-meta">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="vc-icon-xs"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5"/></svg>
                            @v.Departamento
                        </p>
                        <p class="vc-card-text">@v.Direccion</p>
                        @if (!string.IsNullOrEmpty(v.Telefono))
                        {
                            <p class="vc-card-text">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="vc-icon-xs"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.28 2 2 0 0 1 3.6 1h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.5a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                                @v.Telefono
                            </p>
                        }
                        @if (!string.IsNullOrEmpty(v.Horario))
                        {
                            <p class="vc-card-text">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="vc-icon-xs"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                                @v.Horario
                            </p>
                        }
                    </div>
                    <a asp-action="Details" asp-route-id="@v.Id" class="vc-btn-ghost-sm">Ver detalle</a>
                </div>
            }
        </div>
    }
</div>
