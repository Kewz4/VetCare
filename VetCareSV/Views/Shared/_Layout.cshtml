<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — VetCare SV</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;700&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/vetcare.css?v=@VetCareSV.BuildInfo.CacheBust" />
</head>
<body>
<nav class="vc-nav" id="mainNav">
    <a asp-controller="Home" asp-action="Index" class="vc-nav-logo">
        <img src="https://1rdekw89rj.ucarecd.net/320638db-7a49-495c-ac81-ab070918354b/vetcarelogo.png"
             alt="VetCare SV" class="vc-nav-logo-img" />
    </a>
    <div class="vc-nav-links">
        <a asp-controller="Home" asp-action="Index">Inicio</a>
        <a asp-controller="Veterinarias" asp-action="Index">Veterinarias</a>
        <a asp-controller="Comercios" asp-action="Index">Comercios</a>
        @if (Context.Session.GetInt32("UsuarioId") != null)
        {
            @if (Context.Session.GetString("UsuarioRol") == "Admin")
            {
                <a asp-controller="Admin" asp-action="Index" class="vc-badge-admin">Admin</a>
            }
            <div class="vc-user-menu" id="userMenu">
                <button class="vc-user-name" id="userMenuBtn" type="button" onclick="toggleMenu()">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="vc-icon-sm"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
                    @Context.Session.GetString("UsuarioNombre")
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="vc-icon-xs vc-chevron"><path d="M6 9l6 6 6-6"/></svg>
                </button>
                <div class="vc-user-dropdown" id="userDropdown">
                    <a asp-controller="Usuarios" asp-action="Perfil">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="vc-icon-sm"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
                        Mi Perfil
                    </a>
                    <a asp-controller="Mascotas" asp-action="Index">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="vc-icon-sm"><ellipse cx="12" cy="17" rx="5" ry="3.5"/><ellipse cx="6.5" cy="11" rx="2" ry="3"/><ellipse cx="17.5" cy="11" rx="2" ry="3"/><ellipse cx="9" cy="7" rx="1.5" ry="2"/><ellipse cx="15" cy="7" rx="1.5" ry="2"/></svg>
                        Mis Mascotas
                    </a>
                    <a asp-controller="Citas" asp-action="Index">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="vc-icon-sm"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
                        Mis Citas
                    </a>
                    <div class="vc-dropdown-divider"></div>
                    <form asp-controller="Usuarios" asp-action="Logout" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="vc-icon-sm"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                            Cerrar Sesión
                        </button>
                    </form>
                </div>
            </div>
        }
        else
        {
            <a asp-controller="Usuarios" asp-action="Login" class="vc-btn-ghost-sm">Iniciar Sesión</a>
            <button type="button" class="vc-btn-primary-sm vc-btn-register-nav" onclick="openRegisterModal()">Registrarse</button>
        }
    </div>
</nav>

<main class="vc-main">
    @if (TempData["Exito"] != null)
    {
        <div class="vc-toast vc-toast--success" id="vcToast">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="vc-icon-sm"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="vc-toast-msg">@TempData["Exito"]</span>
            <button class="vc-toast-close" onclick="this.parentElement.remove()" type="button">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px;height:16px"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="vc-toast vc-toast--error" id="vcToast">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="vc-icon-sm"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <span class="vc-toast-msg">@TempData["Error"]</span>
            <button class="vc-toast-close" onclick="this.parentElement.remove()" type="button">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px;height:16px"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
    }
    @RenderBody()
</main>

<footer class="vc-footer">
    <div class="vc-footer-inner">
        <div class="vc-footer-logo">
            <img src="https://1rdekw89rj.ucarecd.net/320638db-7a49-495c-ac81-ab070918354b/vetcarelogo.png"
                 alt="VetCare SV" class="vc-footer-logo-img" />
        </div>
        <p class="vc-footer-sub">Sistema de Citas Veterinarias · El Salvador · 2026</p>
        <p class="vc-footer-credit">Kenneth Rodas · Universidad Mónica Herrera</p>
    </div>
</footer>

<script>
const nav = document.getElementById('mainNav');
window.addEventListener('scroll', () => nav.classList.toggle('scrolled', window.scrollY > 40), {passive:true});

// Toast auto-dismiss
const toast = document.getElementById('vcToast');
if (toast) setTimeout(() => toast.classList.add('vc-toast--out'), 4000);

// User menu - click toggle instead of hover
function toggleMenu() {
    const dropdown = document.getElementById('userDropdown');
    const btn = document.getElementById('userMenuBtn');
    const isOpen = dropdown.classList.toggle('open');
    btn.classList.toggle('active', isOpen);
}
// Close when clicking outside
document.addEventListener('click', e => {
    const menu = document.getElementById('userMenu');
    if (menu && !menu.contains(e.target)) {
        document.getElementById('userDropdown')?.classList.remove('open');
        document.getElementById('userMenuBtn')?.classList.remove('active');
    }
});

// Global register modal (available on all pages)
function openRegisterModal() {
    const m = document.getElementById('globalRegisterModal');
    if (m) { m.classList.add('open'); document.body.style.overflow = 'hidden'; }
}
function closeRegisterModal() {
    const m = document.getElementById('globalRegisterModal');
    if (m) { m.classList.remove('open'); document.body.style.overflow = ''; }
}
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeRegisterModal(); });
</script>
@await RenderSectionAsync("Scripts", required: false)

@if (Context.Session.GetInt32("UsuarioId") == null)
{
<div class="vc-modal-overlay" id="globalRegisterModal" onclick="if(event.target===this)closeRegisterModal()">
    <div class="vc-modal">
        <button class="vc-modal-close" onclick="closeRegisterModal()" type="button">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:18px;height:18px"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
        <h2 class="vc-modal-title">Como quieres registrarte?</h2>
        <p class="vc-modal-sub">Elige el tipo de cuenta que mejor describe tu uso de VetCare SV</p>
        <div class="vc-modal-options">
            <a asp-controller="Usuarios" asp-action="Registro" class="vc-modal-option">
                <div class="vc-modal-option-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><ellipse cx="12" cy="17" rx="5" ry="3.5"/><ellipse cx="6.5" cy="11" rx="2" ry="3"/><ellipse cx="17.5" cy="11" rx="2" ry="3"/><ellipse cx="9" cy="7" rx="1.5" ry="2"/><ellipse cx="15" cy="7" rx="1.5" ry="2"/></svg>
                </div>
                <div class="vc-modal-option-text">
                    <strong>Soy dueno de mascotas</strong>
                    <span>Agenda citas y lleva el historial medico</span>
                </div>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="vc-modal-arrow"><path d="M9 18l6-6-6-6"/></svg>
            </a>
            <a asp-controller="Comercios" asp-action="RegistroComercio" class="vc-modal-option vc-modal-option--comercio">
                <div class="vc-modal-option-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l1-5h16l1 5"/><path d="M3 9a2 2 0 0 0 4 0 2 2 0 0 0 4 0 2 2 0 0 0 4 0 2 2 0 0 0 4 0"/><path d="M5 9v11a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V9"/><path d="M10 14h4v6h-4z"/></svg>
                </div>
                <div class="vc-modal-option-text">
                    <strong>Tengo un comercio o clinica</strong>
                    <span>Aparece en el directorio de VetCare SV</span>
                </div>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="vc-modal-arrow"><path d="M9 18l6-6-6-6"/></svg>
            </a>
        </div>
        <p class="vc-modal-footer">Ya tienes cuenta? <a asp-controller="Usuarios" asp-action="Login">Inicia sesion</a></p>
    </div>
</div>
}
</body>
</html>
