@model VetCareSV.Models.ComercioAliado
@{ ViewData["Title"] = "Panel de Comercio"; }
@using System.Collections.Generic
@{
    var productos = ViewBag.Productos as IEnumerable<VetCareSV.Models.Producto> ?? Enumerable.Empty<VetCareSV.Models.Producto>();
    var clientes = ViewBag.Clientes as IEnumerable<(VetCareSV.Models.Usuario Usuario, string Mascota, string Producto, DateTime Fecha)> ?? Enumerable.Empty<(VetCareSV.Models.Usuario, string, string, DateTime)>();
}
<div class="vc-container" style="padding-top:2rem;">
    <div class="vc-page-header">
        <div>
            <h1>Panel de Comercio</h1>
            <p>Bienvenido, <strong>@Model.Nombre</strong></p>
        </div>
        <div style="display:flex;gap:0.75rem;">
            <a asp-action="EditarComercio" class="vc-btn-ghost">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="vc-icon-sm"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                Editar información
            </a>
            <a asp-action="Index" class="vc-btn-ghost">Ver directorio</a>
        </div>
    </div>

    <!-- Stats row -->
    <div class="vc-dash-stats">
        <div class="vc-dash-stat">
            <span class="vc-dash-stat-num">@productos.Count()</span>
            <span class="vc-dash-stat-label">Productos</span>
        </div>
        <div class="vc-dash-stat">
            <span class="vc-dash-stat-num">@clientes.Count()</span>
            <span class="vc-dash-stat-label">Clientes alcanzados</span>
        </div>
        <div class="vc-dash-stat">
            <span class="vc-dash-stat-num">@Model.Categoria</span>
            <span class="vc-dash-stat-label">Categoría</span>
        </div>
        <div class="vc-dash-stat">
            <span class="vc-dash-stat-num" style="font-size:1rem;font-family:'DM Sans',sans-serif;">@Model.Departamento</span>
            <span class="vc-dash-stat-label">Departamento</span>
        </div>
    </div>

    <!-- Productos -->
    <div class="vc-dash-section">
        <div class="vc-page-header" style="margin-bottom:1.25rem;">
            <div>
                <h2>Mis Productos</h2>
                <p>Aparecen como recomendaciones en recetas médicas de usuarios</p>
            </div>
            <button class="vc-btn-primary" onclick="document.getElementById('addProductPanel').classList.toggle('open')" type="button">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="vc-icon-sm"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                Agregar producto
            </button>
        </div>

        <div class="vc-add-panel" id="addProductPanel">
            <div class="vc-add-panel-inner">
                <h3>Agregar producto manualmente</h3>
                <form asp-action="AgregarProducto" method="post" class="vc-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ComercioId" value="@Model.Id" />
                    <div class="vc-form-row">
                        <div class="vc-field">
                            <label>Nombre del producto *</label>
                            <input type="text" name="Nombre" placeholder="Ej. Amoxicilina 250mg" required />
                        </div>
                        <div class="vc-field">
                            <label>Precio ($)</label>
                            <input type="number" name="Precio" step="0.01" min="0" placeholder="0.00" />
                        </div>
                    </div>
                    <div class="vc-field">
                        <label>Descripción</label>
                        <input type="text" name="Descripcion" placeholder="Breve descripción del producto" />
                    </div>
                    <div class="vc-field">
                        <label>URL de imagen</label>
                        <input type="url" name="ImageUrl" placeholder="https://..." />
                        <p class="vc-field-hint">Enlace directo a una imagen del producto (jpg, png, webp)</p>
                    </div>
                    <div class="vc-form-actions">
                        <button type="submit" class="vc-btn-primary">Guardar producto</button>
                    </div>
                </form>

                <div class="vc-divider-label">o subir CSV masivo</div>

                <form asp-action="SubirCSV" method="post" enctype="multipart/form-data" class="vc-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ComercioId" value="@Model.Id" />
                    <div class="vc-field">
                        <label>Archivo CSV</label>
                        <input type="file" name="archivo" accept=".csv" class="vc-file-input" />
                        <p class="vc-field-hint">Formato: <code>Nombre,Descripcion,Precio,ImageUrl</code> — una fila por producto</p>
                    </div>
                    <div class="vc-form-actions">
                        <button type="submit" class="vc-btn-ghost">Subir CSV</button>
                    </div>
                </form>
            </div>
        </div>

        @if (!productos.Any())
        {
            <div class="vc-empty-state">
                <div class="vc-empty-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l1-5h16l1 5"/><path d="M3 9a2 2 0 0 0 4 0 2 2 0 0 0 4 0 2 2 0 0 0 4 0 2 2 0 0 0 4 0"/><path d="M5 9v11a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V9"/><path d="M10 14h4v6h-4z"/></svg></div>
                <p>Aún no tienes productos registrados.</p>
                <p style="color:var(--navy-300);font-size:0.9rem;">Agrega productos para que aparezcan en recetas médicas de los usuarios.</p>
            </div>
        }
        else
        {
            <div class="vc-producto-cards">
                @foreach (var p in productos)
                {
                    <div class="vc-producto-card">
                        @if (!string.IsNullOrEmpty(p.ImageUrl))
                        {
                            <div class="vc-producto-card-img">
                                <img src="@p.ImageUrl" alt="@p.Nombre" />
                            </div>
                        }
                        else
                        {
                            <div class="vc-producto-card-img vc-producto-card-img--empty">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                            </div>
                        }
                        <div class="vc-producto-card-body">
                            <strong class="vc-producto-nombre">@p.Nombre</strong>
                            @if (!string.IsNullOrEmpty(p.Descripcion))
                            { <span class="vc-producto-desc">@p.Descripcion</span> }
                            @if (p.Precio.HasValue)
                            { <span class="vc-producto-precio">$@p.Precio.Value.ToString("0.00")</span> }
                        </div>
                        <form asp-action="EliminarProducto" asp-route-id="@p.Id" method="post" class="vc-producto-card-del">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="vc-btn-danger-sm" onclick="return confirm('¿Eliminar este producto?')">Eliminar</button>
                        </form>
                    </div>
                }
            </div>
        }
    </div>

    <!-- Clientes -->
    <div class="vc-dash-section">
        <div style="margin-bottom:1.25rem;">
            <h2>Clientes alcanzados</h2>
            <p>Usuarios que recibieron recetas médicas con tus productos</p>
        </div>

        @if (!clientes.Any())
        {
            <div class="vc-empty-state">
                <div class="vc-empty-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg></div>
                <p>Aún no hay clientes vinculados a tus productos.</p>
                <p style="color:var(--navy-300);font-size:0.9rem;">Cuando un veterinario recete alguno de tus productos, el cliente aparecerá aquí.</p>
            </div>
        }
        else
        {
            <div class="vc-table-wrapper">
                <table class="vc-table">
                    <thead>
                        <tr>
                            <th>Cliente</th>
                            <th>Correo</th>
                            <th>Mascota</th>
                            <th>Producto recetado</th>
                            <th>Fecha de cita</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in clientes)
                        {
                            <tr>
                                <td><strong>@c.Usuario.Nombre</strong></td>
                                <td style="color:var(--navy-300)">@c.Usuario.Email</td>
                                <td>@c.Mascota</td>
                                <td><span class="vc-chip vc-chip--sm">@c.Producto</span></td>
                                <td>@c.Fecha.ToString("dd/MM/yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
