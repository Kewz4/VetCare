@model VetCareSV.Models.ComercioAliado
@{ ViewData["Title"] = "Panel de Comercio"; }
@{
    var productos = ViewBag.Productos as IEnumerable<VetCareSV.Models.Producto> ?? Enumerable.Empty<VetCareSV.Models.Producto>();
}
<div class="vc-container" style="padding-top:2rem;">
    <div class="vc-page-header">
        <div>
            <h1>Panel de Comercio</h1>
            <p>Gestiona <strong>@Model.Nombre</strong> en el directorio VetCare SV</p>
        </div>
        <a asp-action="Index" class="vc-btn-ghost">Ver directorio</a>
    </div>

    <div class="vc-dashboard-grid">
        <!-- Info del comercio -->
        <div class="vc-card vc-detail-card">
            <h3 style="margin-bottom:1.25rem;color:var(--mint)">Información del comercio</h3>
            <div class="vc-detail-info-grid">
                <div class="vc-detail-info-item">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="vc-icon-sm"><path d="M3 9l1-5h16l1 5"/><path d="M3 9a2 2 0 0 0 4 0 2 2 0 0 0 4 0 2 2 0 0 0 4 0 2 2 0 0 0 4 0"/><path d="M5 9v11a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V9"/><path d="M10 14h4v6h-4z"/></svg>
                    <div><span class="vc-detail-info-label">Nombre</span><span class="vc-detail-info-value">@Model.Nombre</span></div>
                </div>
                <div class="vc-detail-info-item">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="vc-icon-sm"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5"/></svg>
                    <div><span class="vc-detail-info-label">Dirección</span><span class="vc-detail-info-value">@Model.Direccion, @Model.Departamento</span></div>
                </div>
                <div class="vc-detail-info-item">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="vc-icon-sm"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                    <div><span class="vc-detail-info-label">Categoría</span><span class="vc-detail-info-value">@Model.Categoria</span></div>
                </div>
            </div>
        </div>

        <!-- Estadística rápida -->
        <div class="vc-card vc-stat-highlight">
            <div class="vc-stat-big">@productos.Count()</div>
            <div class="vc-stat-big-label">productos registrados</div>
            <p style="color:var(--navy-300);font-size:0.85rem;margin-top:0.5rem;">Estos productos aparecen en las recetas médicas de nuestros usuarios</p>
        </div>
    </div>

    <!-- Productos section -->
    <div style="margin-top:2.5rem;">
        <div class="vc-page-header" style="margin-bottom:1.25rem;">
            <div>
                <h2>Mis Productos</h2>
                <p>Productos que aparecen en recetas médicas de VetCare SV</p>
            </div>
            <button class="vc-btn-primary" onclick="document.getElementById('addProductPanel').classList.toggle('open')">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="vc-icon-sm"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                Agregar producto
            </button>
        </div>

        <!-- Panel agregar producto -->
        <div class="vc-add-panel" id="addProductPanel">
            <div class="vc-add-panel-inner">
                <h3>Agregar producto manualmente</h3>
                <form asp-action="AgregarProducto" method="post" class="vc-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ComercioId" value="@Model.Id" />
                    <div class="vc-form-row">
                        <div class="vc-field">
                            <label>Nombre del producto *</label>
                            <input type="text" name="Nombre" placeholder="Ej. Amoxicilina 250mg" required />
                        </div>
                        <div class="vc-field">
                            <label>Precio ($)</label>
                            <input type="number" name="Precio" step="0.01" min="0" placeholder="0.00" />
                        </div>
                    </div>
                    <div class="vc-field">
                        <label>Descripción</label>
                        <input type="text" name="Descripcion" placeholder="Breve descripción del producto" />
                    </div>
                    <div class="vc-form-actions">
                        <button type="submit" class="vc-btn-primary">Guardar producto</button>
                    </div>
                </form>

                <div class="vc-divider-label">o subir CSV masivo</div>

                <form asp-action="SubirCSV" method="post" enctype="multipart/form-data" class="vc-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ComercioId" value="@Model.Id" />
                    <div class="vc-field">
                        <label>Archivo CSV</label>
                        <input type="file" name="archivo" accept=".csv" class="vc-file-input" />
                        <p class="vc-field-hint">Formato: <code>Nombre,Descripcion,Precio</code> (una línea por producto, sin encabezado requerido)</p>
                    </div>
                    <div class="vc-form-actions">
                        <button type="submit" class="vc-btn-ghost">Subir CSV</button>
                    </div>
                </form>
            </div>
        </div>

        @if (!productos.Any())
        {
            <div class="vc-empty-state">
                <div class="vc-empty-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l1-5h16l1 5"/><path d="M3 9a2 2 0 0 0 4 0 2 2 0 0 0 4 0 2 2 0 0 0 4 0 2 2 0 0 0 4 0"/><path d="M5 9v11a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V9"/><path d="M10 14h4v6h-4z"/></svg></div>
                <p>Aún no tienes productos registrados.</p>
                <p style="color:var(--navy-300);font-size:0.9rem;">Agrega productos para que aparezcan en recetas médicas de usuarios.</p>
            </div>
        }
        else
        {
            <div class="vc-table-wrapper">
                <table class="vc-table">
                    <thead>
                        <tr>
                            <th>Producto</th>
                            <th>Descripción</th>
                            <th>Precio</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in productos)
                        {
                            <tr>
                                <td><strong>@p.Nombre</strong></td>
                                <td style="color:var(--navy-300)">@(p.Descripcion ?? "—")</td>
                                <td>@(p.Precio.HasValue ? "$" + p.Precio.Value.ToString("0.00") : "—")</td>
                                <td>
                                    <form asp-action="EliminarProducto" asp-route-id="@p.Id" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="vc-btn-danger-sm" onclick="return confirm('¿Eliminar este producto?')">Eliminar</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
