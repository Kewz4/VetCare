@model WebAppEscuela.Models.Estudiante

@{
    ViewData["Title"] = "Detalles del Alumno";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>Detalles del Alumno</h1>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                <i class="bi bi-pencil"></i> Editar
            </a>
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-list"></i> Volver
            </a>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label fw-bold">ID:</label>
                    <p>@Model.Id</p>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold">Email:</label>
                    <p>@Model.Email</p>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label fw-bold">Nombre:</label>
                    <p>@Model.Nombre</p>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold">Apellido:</label>
                    <p>@Model.Apellido</p>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label fw-bold">Teléfono:</label>
                    <p>@(string.IsNullOrEmpty(Model.Telefono) ? "N/A" : Model.Telefono)</p>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold">Fecha de Nacimiento:</label>
                    <p>@(Model.FechaNacimiento.HasValue ? Model.FechaNacimiento.Value.ToString("dd/MM/yyyy") : "N/A")</p>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label fw-bold">Estado:</label>
                    <p>
                        @if (Model.Activo)
                        {
                            <span class="badge bg-success">Activo</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Inactivo</span>
                        }
                    </p>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold">Fecha de Registro:</label>
                    <p>@Model.FechaRegistro.ToString("dd/MM/yyyy HH:mm")</p>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-12">
                    <label class="form-label fw-bold">Dirección:</label>
                    <p>@(string.IsNullOrEmpty(Model.Direccion) ? "N/A" : Model.Direccion)</p>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <a asp-action="Index" class="btn btn-secondary">Volver al Listado</a>
    </div>
</div>
